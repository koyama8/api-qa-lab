{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Contrato Cliente",
  "type": "object",
  "required": ["success", "message", "data"],
  "properties": {
    "success": {
      "type": "boolean"
    },
    "message": {
      "type": "string"
    },
    "data": {
      "type": "object",
      "required": ["id", "nome", "email", "cpf", "ativo"],
      "properties": {
        "id": {
          "type": "integer"
        },
        "nome": {
          "type": "string"
        },
        "email": {
          "type": "string"
        },
        "cpf": {
          "type": "string"
        },
        "ativo": {
          "type": "boolean"
        }
      }
    }
  }
}
